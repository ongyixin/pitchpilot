      "block_id": "09a6c2f1-2543-4147-bae5-2909e2a56e7c",
      "text": "ACME CORP — PRODUCT CLAIMS AND COMPLIANCE POLICY\nVersion 2.4 | Effective Date: January 1, 2026",
      "source_type": "policy_document",
      "frame_index": null,
      "timestamp": null,
      "page_number": 1,
      "document_path": "/Users/padlet/instalily/data/sample_policies/sample_policy.txt",
