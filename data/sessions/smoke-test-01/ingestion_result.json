      "text": "6.1 ROI claims must cite the assumption set and methodology.",
      "source_type": "policy_document",
      "frame_index": null,
      "timestamp": null,
      "page_number": 22,
      "document_path": "/Users/padlet/instalily/data/sample_policies/sample_policy.txt",
