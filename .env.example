# --- Gemma 3n multimodal backend ---
# 'huggingface' = full model (text + image + audio) via HuggingFace Transformers
# 'ollama'      = GGUF via local Ollama (text + image only; audio → mlx-whisper)
PITCHPILOT_GEMMA3N_BACKEND=huggingface
PITCHPILOT_GEMMA3N_HF_MODEL_ID=google/gemma-3n-e4b-it

# --- Ollama (used when GEMMA3N_BACKEND=ollama) ---
PITCHPILOT_OLLAMA_BASE_URL=http://localhost:11434
PITCHPILOT_GEMMA3N_MODEL=gemma3n:e4b
PITCHPILOT_GEMMA3_MODEL=gemma3:4b

# --- FunctionGemma router ---
PITCHPILOT_FUNCTION_GEMMA_MODEL_ID=google/gemma-3-1b-it
PITCHPILOT_FUNCTION_GEMMA_LORA_PATH=./fine_tuning/function_gemma/adapter

# Set to false to enable real model inference
PITCHPILOT_MOCK_MODE=true
HOST=0.0.0.0
PORT=8000
