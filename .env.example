OLLAMA_BASE_URL=http://localhost:11434
GEMMA3N_MODEL=gemma-3n:e4b
GEMMA3_MODEL=gemma3:4b
FUNCTION_GEMMA_MODEL_ID=google/gemma-3-1b-it
